              <li><i class="fa-solid fa-certificate mr-2 text-[#F2A900]"></i>{company.credential}</li>
              <li><i class="fa-solid fa-shield-halved mr-2 text-[#F2A900]"></i>{company.trust}</li>
            </ul>
          </div>
        </div>
        <div class="mx-auto mt-8 flex max-w-7xl flex-col gap-3 border-t border-white/10 pt-6 text-xs font-semibold uppercase tracking-[0.18em] text-slate-500 sm:flex-row sm:items-center sm:justify-between">
          <p>&copy; 2026 Quest Roofing. All rights reserved.</p>
          <p>Queen Creek, Arizona</p>
        </div>
      </footer>
    </div>

    <style is:global>
      html {
        scroll-behavior: smooth;
      }

      .view-section:not(.hidden) {
        animation: viewIn 360ms ease both;
      }

      .nav-link {
        position: relative;
        padding: 0.75rem 0.55rem;
        font-size: 0.72rem;
        font-weight: 900;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: rgb(203 213 225);
        transition: color 220ms ease, transform 220ms ease;
      }

      .nav-link:hover,
      .nav-link.is-active {
        color: #F2A900;
        transform: translateY(-1px);
      }

      .nav-link::after {
        content: "";
        position: absolute;
        left: 0.55rem;
        right: 0.55rem;
        bottom: 0.35rem;
        height: 2px;
        transform: scaleX(0);
        transform-origin: center;
        background: #F2A900;
        transition: transform 220ms ease;
      }

      .nav-link.is-active::after,
      .nav-link:hover::after {
        transform: scaleX(1);
      }

      .mobile-nav-link {
        border: 1px solid rgba(255, 255, 255, 0.1);
        padding: 0.85rem 0.75rem;
        text-align: left;
        font-size: 0.78rem;
        font-weight: 900;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: rgb(226 232 240);
        transition: border-color 220ms ease, color 220ms ease, background 220ms ease;
      }

      .mobile-nav-link:hover,
      .mobile-nav-link.is-active {
        border-color: rgba(242, 169, 0, 0.65);
        background: rgba(242, 169, 0, 0.12);
        color: #F2A900;
      }

      .section-kicker {
        display: inline-flex;
        align-items: center;
        gap: 0.65rem;
        color: #F2A900;
        font-size: 0.78rem;
        font-weight: 900;
        letter-spacing: 0.28em;
        text-transform: uppercase;
      }

      .section-kicker::before {
        content: "";
        width: 2.5rem;
        height: 3px;
        background: #F2A900;
      }

      .filter-chip {
        border: 1px solid rgba(255, 255, 255, 0.16);
        background: rgba(255, 255, 255, 0.06);
        padding: 0.75rem 1rem;
        color: rgb(226 232 240);
        font-size: 0.78rem;
        font-weight: 900;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        transition: transform 220ms ease, border-color 220ms ease, background 220ms ease, color 220ms ease;
      }

      .filter-chip.light {
        border-color: rgb(203 213 225);
        background: white;
        color: #0A0B0D;
      }

      .filter-chip:hover,
      .filter-chip.is-active {
        transform: translateY(-2px);
        border-color: #F2A900;
        background: #F2A900;
        color: #0A0B0D;
      }

      .faq-panel {
        max-height: 0;
        overflow: hidden;
        transition: max-height 280ms ease;
      }

      .faq-item.is-open .faq-panel {
        max-height: 260px;
      }

      .faq-item.is-open .faq-icon {
        transform: rotate(45deg);
      }

      .contact-row {
        display: flex;
        align-items: center;
        gap: 1rem;
        border: 1px solid rgba(255, 255, 255, 0.1);
        background: rgba(255, 255, 255, 0.06);
        padding: 1rem;
        color: rgb(226 232 240);
        transition: border-color 220ms ease, transform 220ms ease, color 220ms ease;
      }

      .contact-row:hover {
        transform: translateY(-2px);
        border-color: rgba(242, 169, 0, 0.65);
        color: #F2A900;
      }

      .contact-row i {
        color: #F2A900;
      }

      .field-label {
        display: grid;
        gap: 0.55rem;
        color: rgb(226 232 240);
        font-size: 0.78rem;
        font-weight: 900;
        letter-spacing: 0.14em;
        text-transform: uppercase;
      }

      .field-input {
        width: 100%;
        border: 1px solid rgba(255, 255, 255, 0.16);
        border-radius: 0;
        background: rgba(255, 255, 255, 0.08);
        padding: 0.95rem 1rem;
        color: white;
        outline: none;
        transition: border-color 220ms ease, background 220ms ease, box-shadow 220ms ease;
      }

      .field-input:focus {
        border-color: #F2A900;
        background: rgba(255, 255, 255, 0.12);
        box-shadow: 0 0 0 3px rgba(242, 169, 0, 0.18);
      }

      .field-input option {
        color: #0A0B0D;
      }

      @keyframes viewIn {
        from {
          opacity: 0;
          transform: translateY(10px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      @media (prefers-reduced-motion: reduce) {
        *,
        *::before,
        *::after {
          animation-duration: 0.01ms !important;
          animation-iteration-count: 1 !important;
          scroll-behavior: auto !important;
          transition-duration: 0.01ms !important;
        }
      }
    </style>

    <script is:inline>
      (() => {
        const views = Array.from(document.querySelectorAll('[data-view]'));
        const viewLinks = Array.from(document.querySelectorAll('[data-view-link]'));
        const mobileMenu = document.getElementById('mobile-menu');
        const mobileButton = document.getElementById('mobile-menu-button');
        const validViews = new Set(views.map((view) => view.getAttribute('data-view')));

        function closeMobileMenu() {
          mobileMenu?.classList.add('hidden');
          mobileButton?.setAttribute('aria-expanded', 'false');
        }

        function setView(nextView, updateHash = true) {
          const target = validViews.has(nextView) ? nextView : 'home';

          views.forEach((section) => {
            section.classList.toggle('hidden', section.getAttribute('data-view') !== target);
          });

          viewLinks.forEach((link) => {
            link.classList.toggle('is-active', link.getAttribute('data-view-link') === target);
          });

          closeMobileMenu();

          if (updateHash) {
            history.replaceState(null, '', `#${target}`);
          }

          window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        viewLinks.forEach((link) => {
          link.addEventListener('click', () => {
            const target = link.getAttribute('data-view-link') || 'home';
            setView(target);
          });
        });

        mobileButton?.addEventListener('click', () => {
          const willOpen = mobileMenu?.classList.contains('hidden');
          mobileMenu?.classList.toggle('hidden');
          mobileButton.setAttribute('aria-expanded', String(Boolean(willOpen)));
        });

        const initialHash = window.location.hash.replace('#', '');
        setView(initialHash || 'home', false);

        window.addEventListener('hashchange', () => {
          setView(window.location.hash.replace('#', ''), false);
        });

        function setupFilter(buttonSelector, cardSelector, attribute) {
          const buttons = Array.from(document.querySelectorAll(buttonSelector));
          const cards = Array.from(document.querySelectorAll(cardSelector));

          buttons.forEach((button) => {
            button.addEventListener('click', () => {
              const filter = button.getAttribute(attribute) || 'all';
              buttons.forEach((item) => item.classList.toggle('is-active', item === button));
              cards.forEach((card) => {
                const matches = filter === 'all' || card.getAttribute('data-category') === filter;
                card.classList.toggle('hidden', !matches);
              });
            });
          });
        }

        setupFilter('[data-service-filter]', '[data-service-card]', 'data-service-filter');
        setupFilter('[data-gallery-filter]', '[data-gallery-card]', 'data-gallery-filter');

        document.querySelectorAll('[data-faq-toggle]').forEach((button) => {
          button.addEventListener('click', () => {
            const item = button.closest('.faq-item');
            const group = item?.parentElement;

            group?.querySelectorAll('.faq-item').forEach((sibling) => {
              if (sibling !== item) {
                sibling.classList.remove('is-open');
                sibling.querySelector('[data-faq-toggle]')?.setAttribute('aria-expanded', 'false');
              }
            });

            const isOpen = !item?.classList.contains('is-open');
            item?.classList.toggle('is-open', isOpen);
            button.setAttribute('aria-expanded', String(isOpen));
          });
        });

        const carousel = document.querySelector('[data-carousel]');
        const track = document.querySelector('[data-carousel-track]');
        let offset = 0;
        let lastFrame = 0;
        let paused = false;

        carousel?.addEventListener('pointerenter', () => {
          paused = true;
        });

        carousel?.addEventListener('pointerleave', () => {
          paused = false;
        });

        function animateCarousel(timestamp) {
          if (!lastFrame) {
            lastFrame = timestamp;
          }

          const delta = timestamp - lastFrame;
          lastFrame = timestamp;

          if (track && !paused) {
            const halfWidth = track.scrollWidth / 2;
            if (halfWidth > 0) {
              offset = (offset + delta * 0.04) % halfWidth;
              track.style.transform = `translate3d(${-offset}px, 0, 0)`;
            }
          }

          requestAnimationFrame(animateCarousel);
        }

        requestAnimationFrame(animateCarousel);

        const form = document.querySelector('[data-contact-form]');
        const success = document.getElementById('form-success');

        form?.addEventListener('submit', (event) => {
          event.preventDefault();
          success?.classList.remove('hidden');
          form.reset();
        });
      })();
    </script>
  </body>
</html>
